# ---------------------------------------------------------------------------
# Hostel Booking Platform — Backend environment template
# Copy to `.env` and fill in. All values are optional for local development:
# without R2_* vars the app falls back to local-disk storage automatically.
# ---------------------------------------------------------------------------

# Django
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS — the Vite dev server origin
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------------------------------------------------------------------------
# Cloudflare R2 (S3-compatible). Leave ALL blank to use local-disk fallback.
# DB files and media live in SEPARATE buckets; both must be set to enable R2.
# ---------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# e.g. https://<accountid>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=

# Dedicated bucket for the per-tenant SQLite .db files (keep private).
R2_DB_BUCKET=
# Dedicated bucket for uploaded media (hostel images, verification photos).
R2_MEDIA_BUCKET=
# Public base URL for serving media (optional, for the media bucket)
R2_PUBLIC_URL=

# ---------------------------------------------------------------------------
# Platform superadmin (auto-created by `python manage.py ensure_superadmin`)
# ---------------------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@hostelhub.gh
ADMIN_PASSWORD=change_me_to_something_strong

# Set to true only when you need to reset the password on an existing account.
ADMIN_PASSWORD_FORCE=false

# ---------------------------------------------------------------------------
# Paystack payment gateway
# ---------------------------------------------------------------------------
# Secret key from your Paystack dashboard (sk_live_... or sk_test_...)
PAYSTACK_SECRET_KEY=

# Platform commission rate deducted before paying out manager (default 10%)
PLATFORM_COMMISSION_RATE=0.10

# ---------------------------------------------------------------------------
# Platform identity (shown in emails and the admin settings panel)
# ---------------------------------------------------------------------------
PLATFORM_NAME=HostelHub Ghana
PLATFORM_CONTACT_EMAIL=support@hostelhub.gh

# ---------------------------------------------------------------------------
# Email (SMTP). Leave EMAIL_HOST blank to use the console backend in dev.
# ---------------------------------------------------------------------------
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=HostelHub Ghana <noreply@hostelhub.gh>

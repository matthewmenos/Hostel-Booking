# ---------------------------------------------------------------------------
# Hostel Booking Platform — Backend environment template
# Copy to `.env` and fill in. All values are optional for local development:
# without R2_* vars the app falls back to local-disk storage automatically.
# ---------------------------------------------------------------------------

# Django
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS — the Vite dev server origin
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------------------------------------------------------------------------
# Cloudflare R2 (S3-compatible). Leave ALL blank to use local-disk fallback.
# DB files and media live in SEPARATE buckets; both must be set to enable R2.
# ---------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# e.g. https://<accountid>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=

# Dedicated bucket for the per-tenant SQLite .db files (keep private).
R2_DB_BUCKET=
# Dedicated bucket for uploaded media (hostel images, verification photos).
R2_MEDIA_BUCKET=
# Public base URL for serving media (optional, for the media bucket)
R2_PUBLIC_URL=
